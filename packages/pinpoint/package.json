{
  "name": "@agent-native/pinpoint",
  "version": "0.1.0",
  "type": "module",
  "description": "Visual feedback and annotation tool for agent-native web applications",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/BuilderIO/agent-native",
    "directory": "packages/pinpoint"
  },
  "exports": {
    ".": {
      "browser": "./dist/index.browser.js",
      "default": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    },
    "./primitives": "./dist/primitives/index.js",
    "./server": "./dist/server/index.js",
    "./types": "./dist/types/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest --run"
  },
  "dependencies": {
    "@agent-native/core": "workspace:*",
    "@medv/finder": "^4.0.2",
    "bippy": "^0.5.32",
    "element-source": "^0.0.3",
    "solid-js": "^1.9.10",
    "zod": "^3.23.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@types/express": "^5.0.3",
    "@types/node": "^24.2.1",
    "@types/react": "^18.3.28",
    "babel-preset-solid": "^1.9.10",
    "esbuild-plugin-solid": "^0.6.0",
    "express": "^5.1.0",
    "tsup": "^8.4.0",
    "typescript": "^5.9.2",
    "vite-plugin-solid": "^2.11.0",
    "vitest": "^3.2.4"
  }
}
