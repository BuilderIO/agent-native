{
  "name": "@agent-native/migrate",
  "version": "0.0.1",
  "type": "module",
  "description": "Migration Workbench engine for moving existing apps to agent-native with verifiable, resumable migration runs.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/BuilderIO/agent-native",
    "directory": "packages/migrate"
  },
  "bugs": {
    "url": "https://github.com/BuilderIO/agent-native/issues"
  },
  "homepage": "https://github.com/BuilderIO/agent-native#readme",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./source-nextjs": {
      "types": "./src/source-nextjs.ts",
      "default": "./dist/source-nextjs.js"
    },
    "./target-agent-native": {
      "types": "./src/target-agent-native.ts",
      "default": "./dist/target-agent-native.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest --run",
    "prepack": "cp ../../README.md ./README.md",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "fast-glob": "^3.3.3",
    "nanoid": "^5.1.9",
    "ts-morph": "^28.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.2.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
