{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": false,
    "declarationMap": false,
    "noCheck": true,
    "strict": false
  },
  "include": ["src/cli/**/*.ts"],
  "exclude": [
    "node_modules",
    "dist",
    "src/templates",
    "src/**/*.spec.ts",
    "src/**/*.spec.tsx",
    "src/**/*.e2e-host.tsx"
  ]
}
