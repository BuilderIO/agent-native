  "scripts": {
    "build": "tsc && rm -rf dist/templates && cp -r src/templates dist/templates",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest --run",
    "prepack": "cp ../../README.md ./README.md",
    "prepublishOnly": "npm run build",
