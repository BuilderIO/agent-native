# Cloud database (optional - content works file-only by default)
# Set these to enable cloud sync and public sharing
# DATABASE_URL=libsql://your-db.turso.io
# DATABASE_AUTH_TOKEN=your-auth-token

# AI providers
# GEMINI_API_KEY=
# OPENAI_API_KEY=

# Notion integration
# NOTION_API_KEY=

# Notion OAuth (for connecting user accounts — configure via the onboarding wizard)
# NOTION_CLIENT_ID=
# NOTION_CLIENT_SECRET=

# Auth (production only)
# ACCESS_TOKEN=

# Private Vault first-device admission (production only)
# Generate 32 random bytes as 64 lowercase hexadecimal characters. Rotating
# this value invalidates only unexpired admission challenges (at most 5 minutes).
# CONTENT_PRIVATE_VAULT_GENESIS_CHALLENGE_SECRET=<64-lowercase-hex-characters>
