# Add your Google OAuth credentials here (or configure via the setup wizard in the app)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Database (local SQLite by default, set for remote/cloud database)
# DATABASE_URL=file:./data/app.db
# DATABASE_AUTH_TOKEN=

# Captcha (optional — Cloudflare Turnstile)
# TURNSTILE_SECRET_KEY=
# VITE_TURNSTILE_SITE_KEY=

# Production auth
# ACCESS_TOKEN=your-secret-token

# Cloudflare deployment (set preset in vite.config.ts)
# NITRO_PRESET=cloudflare_pages
